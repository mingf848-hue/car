# Comma-separated target wallets.
SMART_WALLETS=0xYourSmartWallet1,0xYourSmartWallet2

# The user asked for every copied buy to be 5 USDC.
COPY_AMOUNT_USDC=5

# dry_run is the safe default. live requires ACK_TRADING_RISKS=yes and keys below.
EXECUTION_MODE=dry_run
ACK_TRADING_RISKS=no

# Sports-only mode. DeepSeek is used only when Polymarket metadata/keywords are ambiguous.
SPORTS_ONLY=true
USE_DEEPSEEK_CLASSIFIER=true
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Risk controls.
MAX_SLIPPAGE_BPS=150
MAX_LIVE_DAILY_USDC=50
MIN_LEADER_USDC_SIZE=1
COOLDOWN_SECONDS_PER_TOKEN=120
REQUIRE_PRICE_CHECK=true
COPY_HISTORICAL_ON_FIRST_RUN=false
POLL_INTERVAL_SECONDS=20
AUTO_FOLLOW_SELLS=true
SELL_MODE=close_full_on_leader_sell
MIN_SELL_SHARES=0.01

# Compliance/safety check. SG is close-only on the international venue.
BLOCK_ON_GEOBLOCK=true
CLOSE_ONLY_COUNTRY_CODES=SG

# Live Polymarket CLOB settings. Do not paste secrets into chat.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
DERIVE_API_KEY_IF_MISSING=true
