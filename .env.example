# 跟单钱包在网页里添加，不要放在环境变量里。

# 每次跟买固定 5 USDC。
COPY_AMOUNT_USDC=5

# Zeabur 持久化数据库路径。服务需要挂载 Volume 到 /data。
SQLITE_PATH=/data/bot.sqlite3

# 默认模拟模式。真实下单必须改成 live，并配置下面的钱包密钥。
EXECUTION_MODE=dry_run
ACK_TRADING_RISKS=no

# 只跟体育市场。Polymarket 元数据不明确时，才用 DeepSeek 辅助判断。
SPORTS_ONLY=true
USE_DEEPSEEK_CLASSIFIER=true
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 风控参数。
MAX_SLIPPAGE_BPS=150
MAX_LIVE_DAILY_USDC=50
MIN_LEADER_USDC_SIZE=1
COOLDOWN_SECONDS_PER_TOKEN=120
REQUIRE_PRICE_CHECK=true
COPY_HISTORICAL_ON_FIRST_RUN=false
POLL_INTERVAL_SECONDS=5
AUTO_START=true
AUTO_FOLLOW_SELLS=true
SELL_MODE=close_full_on_leader_sell
MIN_SELL_SHARES=0.01

# 地区限制检查。SG 在国际站通常只允许平仓。
BLOCK_ON_GEOBLOCK=true
CLOSE_ONLY_COUNTRY_CODES=SG

# 实盘 Polymarket CLOB 配置。不要把私钥发到聊天里。
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
DERIVE_API_KEY_IF_MISSING=true
